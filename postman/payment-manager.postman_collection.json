        {
          "name": "Provision",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "const id = json?.transactionId || json?.data?.transactionId;",
                  "if (id) pm.collectionVariables.set('transactionId', String(id));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pan\": \"4111111111111111\",\n  \"expMonth\": \"12\",\n  \"expYear\": \"2030\",\n  \"cvv\": \"123\",\n  \"amount\": 25,\n  \"currency\": \"USD\",\n  \"orderId\": \"ORD-1001\",\n  \"processor\": \"nmi\"\n}"
            },
            "url": "{{baseUrl}}/api/nmi/provision"
          }
        },
        {
          "name": "Provision Completion",
          "request": {
            "method": "POST",
            "header": [
