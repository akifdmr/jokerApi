PORT=1453
SOCKET_PORT=5555

# Comma-separated list for allowed frontend origins in production
# Example: https://payment-manager.vercel.app,https://admin.example.com
CORS_ORIGIN=http://localhost:5173

# Optional outbound proxy (for axios requests like NMI / VPOS)
# Example (do NOT commit real credentials):
# HTTPS_PROXY=http://user:pass@host:port
HTTPS_PROXY=
HTTP_PROXY=

# Comma-separated host allowlist for proxy usage.
# If empty, defaults to: secure.nmi.com, api.stripe.com
PROXY_ALLOWLIST=

# Dev only: disables TLS certificate validation on outbound HTTPS (NOT recommended in prod)
ALLOW_INSECURE_TLS=false

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>/<db>?retryWrites=true&w=majority

# Optional API token for protected routes
API_TOKEN=change_me

# Onramper
ONRAMPER_API_KEY=
ONRAMPER_ENVIRONMENT=test

# BIN lookup (binlist default)
BINLOOKUP_BASE_URL=https://lookup.binlist.net
BINLOOKUP_TIMEOUT_MS=5000
BINLOOKUP_CACHE_TTL_MS=86400000
BINLOOKUP_CACHE_MAX=500

# MX (Instant Account Verification + balances)
MX_BASE_URL=https://int-api.mx.com
MX_CLIENT_ID=
MX_API_KEY=
MX_ACCEPT_VERSION=v20250224
MX_TIMEOUT_MS=8000

# Moov (ACH transfers)
MOOV_BASE_URL=https://api.moov.io
MOOV_PUBLIC_KEY=
MOOV_PRIVATE_KEY=
MOOV_CLIENT_ID=
MOOV_CLIENT_SECRET=
MOOV_VERSION=v2024.01.00
MOOV_TIMEOUT_MS=8000

# Whop Company API / App
# Docs currently show company, product and payment resources under api.whop.com
WHOP_BASE_URL=https://api.whop.com
WHOP_API_KEY=
WHOP_DEFAULT_COMPANY_ID=
WHOP_TIMEOUT_MS=8000

# Braintree (PayPal) - required to enable /api/braintree + tokenized onramp checkout
# Sandbox or Production
BRAINTREE_ENVIRONMENT=Sandbox
BRAINTREE_MERCHANT_ID=
BRAINTREE_PUBLIC_KEY=
BRAINTREE_PRIVATE_KEY=
# Optional: map currency -> merchant account id (if you have separate USD/EUR accounts)
BRAINTREE_MERCHANT_ACCOUNT_ID_USD=
BRAINTREE_MERCHANT_ACCOUNT_ID_EUR=

# Global Payments (GP-API / Unified Commerce)
# Sandbox or Production
GLOBALPAYMENTS_ENVIRONMENT=Sandbox
GLOBALPAYMENTS_APP_ID=naFllEe7LPGxil0g0D5Ub7vbu3bejpHjAIcdAPgMfyp181FO
GLOBALPAYMENTS_APP_KEY=QY2p1I8ZIdSP777gyuQc6V4GSmQqZ9dh4UMl24LvyJbHx1Z2VhH5353xkdAUhyxp
GLOBALPAYMENTS_MERCHANT_ID=
GLOBALPAYMENTS_ACCOUNT_ID=
GLOBALPAYMENTS_API_URL=
GLOBALPAYMENTS_WEBHOOK_SECRET=

# NMI / US Bank
NMI_MODE=mock
NMI_SECURITY_KEY=
NMI_ENDPOINT=https://secure.nmi.com/api/transact.php
US_BANK_MERCHANT_KEY=
US_BANK_TERMINAL_ID=0002830008045766832250

# Vakifbank VPOS
VAKIFBANK_MERCHANT_ID=000000046247631
VAKIFBANK_TERMINAL_ID=V2737098
VPOS_ENDPOINT=
VPOS_MERCHANT_ID=
VPOS_TERMINAL_ID=
VPOS_STORE_KEY=
